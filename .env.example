# API Key for pi coding agent
# You can also set this via `pi --provider <name> --api-key <key>`
# or authenticate via `/login` in interactive mode
PI_API_KEY=sk-ant-<your-anthropic-api-key>

# Provider and model configuration
PI_PROVIDER=anthropic
PI_MODEL=claude-sonnet-4-20250514

# Thinking level: off, minimal, low, medium, high, xhigh
PI_THINKING_LEVEL=medium

# Session directory (optional, defaults to ~/.pi/agent/sessions)
# PI_SESSION_DIR=~/.pi/agent/sessions

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MAX_WORKERS=4

# CORS configuration (comma-separated origins, * for all)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
